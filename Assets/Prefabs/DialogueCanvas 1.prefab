--- !u!114 &4204176042606351715
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5981056255502034439}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "It is late at night and I am thinking too hard; the racket smelled still
    of sweat and off brand griptape from the cornerstore by Kirkland. It is in times
    like these, times I rummage a bit too hard through history, times I\u2019ve slouched
    too long in the mundane routine, times I am discontent with the in-creeping morning
    that something starts moving again. It whispers something funny through the crack
    underneath the door and asks to be fed. I never thought I had the strength for
    this: to confront absolutely anything. But in this terrible hour I think I want
    nothing more than to be seven again; so the door swings forth and in a fraction
    of a second I see your backside scampering. I never thought I had the strength
    for this: the chase and the re-openings. But somehow I find myself scrambling,
    starving to catch you\u2014here we were behind closed doors, socking strangers
    a couple hours south side, past the thousand fainting lilacs brushing along their
    sweets, through the fresh break of dawn and splitting of an in-season peach.
    Oh come on! Please stop moving so quickly! Can\u2019t you just sit here for a
    while? Just like we used to do? Dancing your way into the jaws of another injury,
    sticking your hands into the dirt and then your nose before dozing off alongside
    the sun. Doors, through doors, through doors we run and I am so close to grabbing
    your wrist again. Doors and doors make their re-openings and I think I might
    be bed-bound by morning. Can you just please just stop running away? I have missed
    you more than I could remember and I just want to see your face. But you turn
    the corner and I\u2019ve lost you again and I still, for the life of me, can\u2019t
    find a way to remember the last thing you said that day. I am nothing but you
    in sheep's clothing and you were nothing short of a shooting star. I love you.
    Do you hear me? I love you, so much so, I will spend my life opening these times
    trying to find you, again and again.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
